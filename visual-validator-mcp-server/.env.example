# visual-validator-mcp-server environment variables
# Copy to .env or set in Claude Code's ~/.claude.json mcpServers.env block

# ── Capture ────────────────────────────────────────────────────────────────────
VV_PAGE_LOAD_TIMEOUT_MS=30000
VV_CAPTURE_TIMEOUT_MS=30000

# ── CNN ────────────────────────────────────────────────────────────────────────
VV_CNN_ENABLED=true
VV_CNN_THRESHOLD=0.5          # 0.0–1.0, higher = less sensitive

# ── Rule: empty_state ──────────────────────────────────────────────────────────
VV_EMPTY_STDDEV_ERROR=10
VV_EMPTY_STDDEV_WARNING=20
VV_EMPTY_WHITE_RATIO_ERROR=0.97
VV_EMPTY_WHITE_RATIO_WARNING=0.90

# ── Rule: alignment ────────────────────────────────────────────────────────────
VV_ALIGNMENT_ERROR_RATIO=0.55   # below this → error
VV_ALIGNMENT_WARNING_RATIO=0.70 # below this → warning
VV_ALIGNMENT_PEAK_TOLERANCE=12  # ±px around alignment axis

# ── Rule: color_contrast ───────────────────────────────────────────────────────
VV_CONTRAST_FAIL_RATIO_ERROR=0.25    # >25% low-contrast cells → error
VV_CONTRAST_FAIL_RATIO_WARNING=0.10  # >10% → warning
VV_CONTRAST_MIN_RANGE=0.06           # minimum luminance range to analyse a cell

# ── Rule: spacing ──────────────────────────────────────────────────────────────
VV_SPACING_CV_ERROR=0.9      # coefficient of variation above this → error
VV_SPACING_CV_WARNING=0.55
VV_SPACING_MIN_GAP_PX=3
VV_SPACING_MIN_GAPS=4        # minimum gaps required to analyse

# ── Rule: overflow ─────────────────────────────────────────────────────────────
VV_OVERFLOW_DENSITY_ERROR=0.18
VV_OVERFLOW_DENSITY_WARNING=0.10
VV_OVERFLOW_STRIP_PX=6       # boundary strip width for edge detection

# ── Rule: whitespace ───────────────────────────────────────────────────────────
VV_WHITESPACE_RATIO_ERROR=0.93
VV_WHITESPACE_RATIO_WARNING=0.82
VV_WHITESPACE_IMBALANCE_ERROR=0.55
VV_WHITESPACE_IMBALANCE_WARNING=0.30

# ── Scoring ────────────────────────────────────────────────────────────────────
VV_PASS_THRESHOLD=70    # score >= this → pass
VV_ERROR_PENALTY=25     # points deducted per error result
VV_WARNING_PENALTY=10   # points deducted per warning result
